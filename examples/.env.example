# AppAtOnce SDK Examples Environment Configuration
# Copy this file to .env and fill in your values

# Your AppAtOnce API Key (required)
# Get your API key from:
# - For Developers: https://appatonce.com/login → Create Project → Copy API Key  
# - For No-Code Users: Generate a complete app at https://appatonce.com and get your API key with the project
APPATONCE_API_KEY=your_api_key_here

# Optional: AppAtOnce server endpoint (defaults to http://localhost:8091)
# APPATONCE_ENDPOINT=http://localhost:8091

# Optional: Debug mode for detailed logging
# DEBUG=true